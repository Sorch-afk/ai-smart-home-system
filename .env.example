# API Keys (留空则使用本地回退模式)
# 通义千问 API Key - https://dashscope.aliyun.com/
QWEN_API_KEY=sk-xxxxx

# Xiaomi Mimo API Key (申请地址)
MIMO_API_KEY=

# 首选模型 (qwen / mimo / local)
PREFERRED_MODEL=qwen

# API 配置 (一般不用改)
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
MIMO_BASE_URL=https://mimo.api.xiaomi.com/v1
MIMO_MODEL=mimo-v2
